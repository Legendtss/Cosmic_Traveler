# ── Required in production ─────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string

# ── Optional API keys ─────────────────────────────────────
GEMINI_API_KEY=           # Google Gemini — enables AI chat
USDA_API_KEY=DEMO_KEY     # USDA FoodData Central — nutrition search

# ── Database ──────────────────────────────────────────────
# DATABASE_URL=            # Default: SQLite at data/fitness.sqlite

# ── CORS (comma-separated origins) ────────────────────────
# CORS_ORIGINS=https://yourdomain.com

# ── Production flags (set any to truthy to enable) ────────
# RENDER=1
# RAILWAY_ENVIRONMENT=production
# PRODUCTION=1
